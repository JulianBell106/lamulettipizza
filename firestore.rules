// ============================================================================
// Stalliq — Firestore Security Rules
// Session 16b — April 2026 | Updated Session 19 — loyalty stamps + offer usage
//
// Auth model:
//   Customer ordering: Firebase Phone Auth  (provider == 'phone')
//   Kitchen dashboard: Firebase Anonymous Auth (signed in on successful PIN)
//   Public reads:      No auth required (menu, kitchen status, location)
//
// HOW TO DEPLOY:
//   1. Go to https://console.firebase.google.com → stalliq project
//   2. Firestore Database → Rules tab
//   3. Replace ALL existing content with everything below the separator line
//   4. Click "Publish"
// ============================================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────

    /** True if the request comes from any authenticated Firebase session
        (phone auth OR anonymous auth). */
    function isAuthenticated() {
      return request.auth != null;
    }

    /** True if the request comes from a Phone Auth user (i.e. a customer). */
    function isPhoneAuth() {
      return request.auth != null
          && request.auth.token.firebase.sign_in_provider == 'phone';
    }

    /** True if the request comes from an Anonymous Auth session (i.e. the
        kitchen dashboard after a successful PIN login). */
    function isAnonymousAuth() {
      return request.auth != null
          && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    /** True if the requesting user owns this document (customer reads their
        own profile or their own order). */
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }


    // ── Vendor document ─────────────────────────────────────────────────────
    //
    // vendors/{vendorId}
    //   Public read: kitchenStatus needs to be readable without auth so the
    //   customer app can show the open/closed pill even before sign-in.
    //   Write: kitchen only (anonymous auth after PIN login).

    match /vendors/{vendorId} {
      allow read:  if true;
      allow write: if isAnonymousAuth();

      // ── Location broadcast ───────────────────────────────────────────────
      // vendors/{vendorId}/location/current
      //   Public read: customer Find Us page shows the map without auth.
      //   Write: kitchen anonymous session only.

      match /location/{docId} {
        allow read:  if true;
        allow write: if isAnonymousAuth();
      }

      // ── Staff collection ─────────────────────────────────────────────────
      // vendors/{vendorId}/staff/{staffId}
      //   Read & write: any authenticated session.
      //   On login: the kitchen signs in anonymously BEFORE querying this
      //   collection, so anonymous auth is the minimum required.

      match /staff/{staffId} {
        allow read, write: if isAuthenticated();
      }

      // ── Daily order counter ──────────────────────────────────────────────
      // vendors/{vendorId}/counters/daily

      match /counters/{docId} {
        allow read, write: if isAuthenticated();
      }
    }


    // ── Orders ──────────────────────────────────────────────────────────────
    //
    // orders/{orderId}
    //
    //   CREATE: Any authenticated session (phone customer or anonymous kitchen).
    //   READ:   Kitchen reads all; customer reads own orders only.
    //   UPDATE: Kitchen updates status/waitMins etc.
    //           Customer may set stampsAwarded:true on their own order only
    //           (narrow write added Session 19 for loyalty stamp recording).
    //   DELETE: Nobody.

    match /orders/{orderId} {
      allow create: if isAuthenticated();

      allow read: if isAnonymousAuth()
                  || (isPhoneAuth()
                      && resource.data.customerId == request.auth.uid);

      // Kitchen full update
      allow update: if isAnonymousAuth();

      // Customer narrow update — stamp award only (stampsAwarded field only)
      allow update: if isPhoneAuth()
                    && resource.data.customerId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['stampsAwarded']);

      allow delete: if false;
    }


    // ── User profiles ────────────────────────────────────────────────────────
    //
    // users/{uid}
    //   Customer reads/writes own profile. stampCount field lives here.
    //   Kitchen has no legitimate reason to read user profiles.

    match /users/{uid} {
      allow read, write: if isOwner(uid);

      // ── Offer usage sub-collection ─────────────────────────────────────
      // users/{uid}/offerUsage/{offerId}
      //   Customer reads and writes their own usage counters only.
      //   Used to enforce per-customer max_uses limits on offers.

      match /offerUsage/{offerId} {
        allow read, write: if isOwner(uid);
      }
    }


    // ── Catch-all deny ───────────────────────────────────────────────────────
    // Any path not explicitly matched above is denied by default in Firestore.

  }
}
